{
  "name": "linkdapply",
  "version": "1.1.0",
  "description": "Production-ready Electron wrapper for LinkdApply",
  "main": "main.js",
  "author": "LinkdApply",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yhimanshu22/Auto_job_applier_linkedIn.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build --win --publish never",
    "release:github": "electron-builder build --win --publish always"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.4",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.linkdapply.app",
    "productName": "LinkdApply",
    "copyright": "Copyright © 2024 LinkdApply",
    "artifactName": "LinkdApply-Setup.${ext}",
    "protocols": [
      {
        "name": "LinkdApply",
        "schemes": [
          "linkdapply"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LinkdApply"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yhimanshu22",
        "repo": "Auto_job_applier_linkedIn"
      }
    ],
    "extraResources": [
      {
        "from": "../backend/dist/server",
        "to": "backend"
      },
      {
        "from": "../backend/config",
        "to": "backend/config"
      },
      {
        "from": "node.exe",
        "to": "node.exe"
      },
      {
        "from": "../frontend/.next/standalone",
        "to": "frontend_standalone"
      },
      {
        "from": "../frontend/.env.local",
        "to": "frontend_standalone/.env.local"
      }
    ]
  }
}
