{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkdApply",
  "version": "1.1.5",
  "identifier": "com.linkdapply.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "dmg",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/linkdapply-backend"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "linkdapply"
        ]
      }
    }
  }
}
