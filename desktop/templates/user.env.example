# Optional overrides for the packaged app (%LOCALAPPDATA%\LinkdApply\.env on Windows).
# Production URLs are already built into the MSI — you only need this file for extras.
#
# LinkedIn credentials, resumes, and bot settings are configured in the dashboard UI.
# Do NOT set DATABASE_URL here (local SQLite is used automatically).

# Optional: your own LLM API key (or save via dashboard → stored locally)
# LLM_API_KEY=

# Advanced: point at a self-hosted frontend/backend (defaults are LinkdApply cloud)
# FRONTEND_URL=https://frontend-pink-phi-37.vercel.app
# CLOUD_API_URL=https://linkedapply-backend.onrender.com
