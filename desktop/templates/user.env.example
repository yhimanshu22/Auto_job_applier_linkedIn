# Optional overrides for the packaged sidecar (%LOCALAPPDATA%\LinkdApply\.env on Windows).
# Configs, LinkedIn secrets, applications, and bot logs stay in local SQLite — do NOT set DATABASE_URL here.

ENCRYPTION_KEY=same-as-aws-backend

# Must match desktop/.env and AWS backend
CLOUD_API_URL=https://api.yourdomain.com
LINKDAPPLY_INTERNAL_KEY=same-shared-secret

# CORS for the hosted dashboard calling this machine
FRONTEND_URL=https://app.yourdomain.com
EXTRA_CORS_ORIGINS=https://app.yourdomain.com

# Optional: user's own LLM keys (or save via dashboard → stored locally)
# LLM_API_KEY=
