# =============================================================================
# LinkdApply Desktop — copy to desktop/.env
# =============================================================================

# --- Local dev (start frontend first: cd frontend && npm run dev) ---
# LINKDAPPLY_FRONTEND_URL=http://localhost:3000/login?desktop=1&callbackUrl=%2Fdashboard%3Fdesktop%3D1
# FRONTEND_URL=http://localhost:3000
# NEXTAUTH_SESSION_URL=http://localhost:3000/api/auth/session
# EXTRA_CORS_ORIGINS=http://localhost:3000
# CLOUD_API_URL=
# LINKDAPPLY_INTERNAL_KEY=

# --- Production (Vercel dashboard + Render billing) ---
LINKDAPPLY_FRONTEND_URL=https://frontend-pink-phi-37.vercel.app/login?desktop=1&callbackUrl=%2Fdashboard%3Fdesktop%3D1
FRONTEND_URL=https://frontend-pink-phi-37.vercel.app
NEXTAUTH_SESSION_URL=https://frontend-pink-phi-37.vercel.app/api/auth/session
EXTRA_CORS_ORIGINS=https://frontend-pink-phi-37.vercel.app

CLOUD_API_URL=https://linkedapply-backend.onrender.com
LINKDAPPLY_INTERNAL_KEY=your-long-random-secret

LINKDAPPLY_API_PORT=8000
