# Hosted dashboard URL (login + billing only)
LINKDAPPLY_FRONTEND_URL=https://app.yourdomain.com/dashboard?desktop=1

# Cloud API on AWS (subscriptions + Stripe/PayU webhooks)
CLOUD_API_URL=https://api.yourdomain.com

# Shared secret — same value on AWS backend and local sidecar
LINKDAPPLY_INTERNAL_KEY=generate-a-long-random-string

# Local sidecar port (default 8000)
LINKDAPPLY_API_PORT=8000
